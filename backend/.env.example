# Ollama Configuration
# URL where Ollama is running (default is localhost:11434)
OLLAMA_URL=http://localhost:11434

# HuggingFace Token
# Required for downloading Indic models (TTS, STT)
HUGGINGFACE_TOKEN=hf_your_actual_token_here

# Optional: Custom cache directory for models
# If not set, models will be cached in default HuggingFace cache directory
# Useful if you want to store models in a specific location
# HF_CACHE_DIR=/path/to/cache/directory

# Google OAuth Configuration
# See GOOGLE_CALENDAR_SETUP.md for detailed instructions
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
